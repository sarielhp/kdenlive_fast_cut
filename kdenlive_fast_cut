#!/usr/bin/env ruby

require 'pathname'
require 'open3'
require 'rainbow'
require 'fileutils'

VERSION = "0.1"

def format_time(seconds)
  min = seconds.to_i / 60
  sec = seconds.to_i % 60
  if min > 0
    format("%dm %02ds", min, sec)
  else
    format("%ds", sec)
  end
end

def show_progress(label, pct, start_time)
  return if pct <= 0
  
  elapsed = Time.now - start_time
  remaining = (elapsed / pct) * (100 - pct)
  bar_size = 20
  filled = (pct / (100.0 / bar_size)).to_i
  bar = "█" * filled + "░" * (bar_size - filled)
  
  print "\r#{Rainbow("#{label}: [#{bar}] #{pct.to_s.rjust(3)}%").blue} | " \
        "Elapsed: #{Rainbow(format_time(elapsed)).cyan} | " \
        "ETR: #{Rainbow(format_time(remaining)).yellow}   "
  $stdout.flush
end

def get_duration(path)
  cmd = ["ffprobe", "-v", "error", "-show_entries", "format=duration", "-of", "default=noprint_wrappers=1:nokey=1", path.to_s]
  stdout, status = Open3.capture2(*cmd)
  status.success? ? stdout.to_f : 0
rescue
  0
end

$command_times = []

def record_time(label, duration, always: false)
  $command_times << [label, duration] if always || duration > 5
end

def print_times
  $command_times.each do |label, duration|
    puts "Time taken for #{label}: #{Rainbow(format_time(duration)).bold}"
  end
end

